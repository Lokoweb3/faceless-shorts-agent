# ==============================================================
#  Soccer Shorts Agent — environment configuration
#  --------------------------------------------------------------
#  1. Copy this file to ".env" in the same folder as agent.py
#       (WSL:  cp .env.example .env )
#  2. Fill in your keys below.
#
#  FORMAT RULES (important):
#   - bare  KEY=value   (no "export", no quotes)
#   - NO spaces around the "="
#   - NO inline comments on a value line  ->  put comments on their own line
# ==============================================================


# ---- YouTube upload credentials (REQUIRED to publish) --------
# Easiest way: run the guided wizard — it walks you through the Google
# Cloud steps, opens the sign-in, and fills these three values in for you:
#     python3 setup_oauth.py        (or: ./run.sh --auth)
# NOTE: set your OAuth consent screen to "In production" (the wizard
# explains how) or Google expires the refresh token every 7 days.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Optional: override the YouTube category (auto-picked per CONTENT_MODE:
# soccer=17 Sports, horror/scifi=24 Entertainment, bible=22 People & Blogs)
# YOUTUBE_CATEGORY_ID=

# Custom thumbnails are OFF by default: Shorts don't display them, the
# upload costs API quota, and unverified channels get errors from it.
UPLOAD_THUMBNAILS=false


# ---- Content mode -------------------------------------------
# CONTENT_MODE options:  soccer  |  horror  |  scifi
#   soccer  = news-driven soccer Shorts (discovers current stories)
#   horror  = original AI-generated scary stories (no news needed)
#   scifi   = original near-future AI / tech-horror stories
# For horror and scifi, AI-image visuals are recommended (set ASSET_PROVIDER=ai_image).
CONTENT_MODE=soccer

# AUTO_PREMISES=true makes horror/scifi modes invent brand-new premises every run
# (infinite, never-repeating) instead of using the built-in pool of 25.
AUTO_PREMISES=false


# ---- Script writer: Ollama Cloud (qwen3.5) -------------------
# Get a key at https://ollama.com/settings/keys
OLLAMA_API_KEY=PUT_YOUR_OLLAMA_KEY_HERE
LOCAL_MODEL_ENDPOINT=https://ollama.com/api/generate
LOCAL_MODEL_NAME=qwen3.5:cloud


# ---- Voice (narration) --------------------------------------
# Leave TTS_VOICE blank for the default. Some good free edge-tts voices:
#   en-US-GuyNeural          deep, natural US male
#   en-US-ChristopherNeural  deep, authoritative US male (great for horror)
#   en-US-DavisNeural        calm, measured US male
#   en-GB-RyanNeural         energetic British male (default)
#   en-US-AriaNeural         expressive US female
#   en-GB-SoniaNeural        British female
# TTS_RATE: speed (-10% slower for horror, +15% faster for hype)
# TTS_VOLUME: loudness (e.g. +0%)
TTS_VOICE=
TTS_RATE=+10%
TTS_VOLUME=+0%

# ---- Premium voice: ElevenLabs (optional, paid) -------------
# If ELEVENLABS_API_KEY + ELEVENLABS_VOICE_ID are set, ElevenLabs is used
# instead of edge-tts (with synced captions). Leave blank to use free edge-tts.
# Get a voice ID from your ElevenLabs Voice Library (copy the voice's ID).
# Models: eleven_multilingual_v2 (quality) | eleven_flash_v2_5 (fast/cheap) | eleven_v3
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY=0.75


# ---- Visuals ------------------------------------------------
# ASSET_PROVIDER options:  ai_image  |  pexels  |  generated
ASSET_PROVIDER=ai_image

# AI "animated story" images via Pollinations (free, no key needed).
# AI_IMAGE_MODEL options:  flux | turbo | flux-realism | flux-anime | flux-3d
AI_IMAGE_MODEL=flux
AI_IMAGE_STYLE=cinematic dramatic digital illustration, epic lighting, no text
# Optional Pollinations key for speed/reliability (https://enter.pollinations.ai)
POLLINATIONS_API_KEY=

# Rate-limit protection: minimum seconds between image requests, and how
# long each background segment runs (longer = fewer images per video).
# Successful images are also cached in data/image_cache/ and reused as the
# fallback when Pollinations rate-limits, instead of a plain gradient.
AI_IMAGE_MIN_INTERVAL=4
SECONDS_PER_CLIP=8

# Licensed stock footage — only used when ASSET_PROVIDER=pexels
# Free key at https://www.pexels.com/api
PEXELS_API_KEY=


# ---- Optional: alternative script AI providers --------------
# If ANY of these is set it OVERRIDES Ollama.
# Priority order: Grok > OpenAI > Anthropic > Ollama.
# Leave blank to keep using Ollama Cloud above.
# XAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-fable-5


# ---- Optional: channel identity (script voice / niche) ------
# CHANNEL_STYLE=Dramatic 'forgotten legends' storytelling, one player per video


# ---- Optional: scheduling cadence (continuous mode) ---------
# CHECK_INTERVAL_MINUTES=60
# MAX_DAILY_UPLOADS=2

# ---- Upload privacy ----------------------------------------
# private (only you) | unlisted (link only) | public (live)
# Keep private until you have verified videos look right, then switch to public.
UPLOAD_PRIVACY=private

# ---- Channel name (shown in video descriptions) -------------
CHANNEL_NAME=
